{
  "mcpServers": {
    "tradingview": {
      "command": "node",
      "args": ["C:/Users/jones.wong/tradingview-mcp/src/server.js"]
    },
    "financial-analysis": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "financial_services"]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": { "BRAVE_API_KEY": "${BRAVE_API_KEY}" }
    },
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "${DB_PATH:-./data/finance.db}"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexityai/mcp-server"],
      "env": { "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}" }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}" }
    },
    "glif": {
      "command": "npx",
      "args": ["-y", "glif-mcp-server"],
      "env": { "GLIF_API_TOKEN": "${GLIF_API_TOKEN}" }
    },
    "chrome": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"]
    },
    "polymarket": {
      "command": "${POLYMARKET_PYTHON:-python3}",
      "args": ["-m", "polymarket_mcp"],
      "env": {
        "DEMO_MODE": "true",
        "POLYGON_PRIVATE_KEY": "${POLYGON_PRIVATE_KEY}",
        "POLYGON_ADDRESS": "${POLYGON_ADDRESS}"
      }
    }
  }
}
